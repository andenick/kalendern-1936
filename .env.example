# Kalendern — example environment configuration
# Copy to .env and edit. NEVER commit a real .env.

# Data + output roots
DATA_ROOT=./data
OUTPUT_ROOT=./outputs

# Python interpreter for CPU OCR steps (defaults to the current interpreter)
# NATIVE_PY=/path/to/python

# Multi-engine consensus fusion: directory containing consensus_entropy.py
# (a dependency-free fallback is embedded, so this is optional)
# CONSENSUS_HARNESS=/path/to/consensus_harness

# Local VLM serving via llama.cpp
# LLAMA_SERVER=/path/to/llama.cpp/llama-server
# MODELS_DIR=./models

# Gold pages / fine-tuning (optional)
# GOLD_DIR=./data/gold
# MODEL_DIR=./models/LightOnOCR-2-1B
# EVAL_HARNESS=/path/to/eval_harness
